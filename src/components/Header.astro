---
import type { Team } from "../data/siteData";

type NavItem = {
  label: string;
  href: string;
  match: string;
};

type Props = {
  team: Team;
  currentPath?: string;
};

const { team, currentPath = "/" } = Astro.props;
const navItems: NavItem[] = [
  { label: "首页", href: "/", match: "/" },
  { label: "战队", href: "/#team", match: "/#team" },
  { label: "兵种", href: "/units/", match: "/units/" },
  { label: "媒体", href: "/media/", match: "/media/" }
];

function isCurrent(item: NavItem) {
  if (item.match === "/#team") return false;
  return currentPath === item.match;
}
---

<header class="site-header">
  <a class="brand" href="/" aria-label="RoboMaster 战队展示首页">
    <span class="brand-mark">{team.logo}</span>
    <span class="brand-text">{team.name}</span>
  </a>
  <nav class="main-nav" aria-label="主导航">
    {
      navItems.map((item) => (
        <a class:list={{ "is-current": isCurrent(item) }} href={item.href}>
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
