---
import type { Team } from "../data/siteData";
import { withBase } from "../utils/paths";

type NavItem = {
  label: string;
  href: string;
  match: string;
};

type Props = {
  team: Team;
  currentPath?: string;
};

const { team, currentPath = "/" } = Astro.props;
const navItems: NavItem[] = [
  { label: "首页", href: "/", match: "/" },
  { label: "战队", href: "/#team", match: "/#team" },
  { label: "兵种", href: "/units/", match: "/units/" },
  { label: "媒体", href: "/media/", match: "/media/" }
];

function isCurrent(item: NavItem) {
  if (item.match === "/#team") return false;
  const normalizedPath = currentPath.replace(import.meta.env.BASE_URL.replace(/\/$/, ""), "") || "/";
  return normalizedPath === item.match;
}
---

<header class="site-header">
  <a class="brand" href={withBase("/")} aria-label={`${team.name}首页`}>
    <span class="brand-mark">
      <img src={withBase(team.emblem)} alt="" width="42" height="42" />
    </span>
    <span class="brand-text">{team.name}</span>
  </a>
  <nav class="main-nav" aria-label="主导航">
    {
      navItems.map((item) => (
        <a class:list={{ "is-current": isCurrent(item) }} href={withBase(item.href)}>
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
