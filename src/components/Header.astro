---
import { withBase } from "../utils/paths";

type NavItem = {
  label: string;
  href: string;
  match: string;
};

type Props = {
  currentPath?: string;
};

const { currentPath = "/" } = Astro.props;
const navItems: NavItem[] = [
  { label: "首页", href: "/", match: "/" },
  { label: "战队", href: "/#team", match: "/#team" },
  { label: "兵种", href: "/units/", match: "/units/" },
  { label: "分工", href: "/division/", match: "/division/" },
  { label: "媒体", href: "/media/", match: "/media/" },
  { label: "荣誉", href: "/honors/", match: "/honors/" },
  { label: "联系", href: "/contact/", match: "/contact/" }
];

function isCurrent(item: NavItem) {
  if (item.match === "/#team") return false;
  const normalizedPath = currentPath.replace(import.meta.env.BASE_URL.replace(/\/$/, ""), "") || "/";
  if (item.match === "/") return normalizedPath === "/";

  return normalizedPath === item.match || normalizedPath.startsWith(item.match);
}
---

<header class="site-header">
  <nav class="main-nav" aria-label="主导航">
    {
      navItems.map((item) => (
        <a class:list={{ "is-current": isCurrent(item) }} href={withBase(item.href)}>
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
