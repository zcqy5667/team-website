---
import type { Unit } from "../data/siteData";
import OptimizedImage from "./OptimizedImage.astro";
import TagList from "./TagList.astro";
import { withBase } from "../utils/paths";

type Props = {
  unit: Unit;
  preview?: boolean;
};

const { unit, preview = false } = Astro.props;
const functions = preview ? unit.functions.slice(0, 2) : unit.functions;
const unitHref = withBase(`/units/${unit.id}/`);
---

<article
  class="unit-card"
  id={unit.id}
  tabindex="0"
  data-card-type="unit"
  data-modal-card
  data-modal-href={unitHref}
  aria-label={`打开 ${unit.name} 预览`}
>
  <div class="unit-card-link">
    <div class="unit-visual">
      <OptimizedImage src={unit.image} alt={`${unit.name}示意图`} loading="lazy" />
      <span class="unit-number">{unit.number}</span>
    </div>
    <div class="unit-body">
      <span class="unit-role">{unit.role}</span>
      <h3>{unit.name}</h3>
      <p>{unit.summary}</p>
      <TagList items={functions} className="function-list" />
      <TagList items={unit.tags} className="tag-list" />
      <button class="card-detail-button" type="button" data-modal-trigger>查看详情</button>
    </div>
  </div>
</article>
