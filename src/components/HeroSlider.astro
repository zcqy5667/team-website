---
import type { HeroSlide } from "../data/siteData";

type Props = {
  slides: HeroSlide[];
};

const { slides } = Astro.props;
---

<section class="hero-slider" data-hero-slider aria-label="首页轮播" style={`--slide-count: ${slides.length}`}>
  <div class="slide-track" data-slide-track>
    {
      slides.map((slide, index) => (
        <article class:list={["hero-slide", { "is-active": index === 0 }]} data-slide={index} aria-hidden={index === 0 ? "false" : "true"}>
          <img class="hero-slide-image" src={slide.image} alt="" />
          <div class="hero-slide-shade"></div>
          <div class="hero-slide-content">
            <p class="eyebrow">{slide.kicker}</p>
            <h1>{slide.title}</h1>
            <p class="hero-copy">{slide.description}</p>
            <div class="hero-actions">
              <a class="button button-primary" href={slide.primaryHref}>{slide.primaryLabel}</a>
            </div>
          </div>
        </article>
      ))
    }
  </div>
  <button class="slide-arrow slide-arrow-prev" type="button" data-slide-prev aria-label="上一张">‹</button>
  <button class="slide-arrow slide-arrow-next" type="button" data-slide-next aria-label="下一张">›</button>
  <div class="slide-controls">
    <div class="slide-dots" data-slide-dots aria-label="轮播指示器">
      {
        slides.map((_slide, index) => (
          <button class:list={["slide-dot", { "is-active": index === 0 }]} type="button" data-slide-dot={index} aria-label={`切换到第 ${index + 1} 张轮播`}></button>
        ))
      }
    </div>
    <div class="slide-progress" data-slide-progress aria-hidden="true"></div>
  </div>
</section>

<script>
  const slider = document.querySelector<HTMLElement>("[data-hero-slider]");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (slider) {
    const track = slider.querySelector("[data-slide-track]");
    const dots = slider.querySelector("[data-slide-dots]");
    const progress = slider.querySelector<HTMLElement>("[data-slide-progress]");
    const previous = slider.querySelector("[data-slide-prev]");
    const next = slider.querySelector("[data-slide-next]");
    const slides = Array.from(slider.querySelectorAll<HTMLElement>("[data-slide]"));
    let current = 0;
    let timer: number | null = null;
    let startX = 0;

    function activate(index: number) {
      if (slides.length === 0) return;
      current = (index + slides.length) % slides.length;
      slides.forEach((slide, slideIndex) => {
        const isActive = slideIndex === current;
        slide.classList.toggle("is-active", isActive);
        slide.setAttribute("aria-hidden", isActive ? "false" : "true");
      });
      dots?.querySelectorAll("[data-slide-dot]").forEach((dot, dotIndex) => {
        dot.classList.toggle("is-active", dotIndex === current);
      });
      progress?.style.setProperty("--progress-index", String(current + 1));
    }

    function stop() {
      if (timer) window.clearInterval(timer);
      timer = null;
    }

    function start() {
      if (reduceMotion || timer || slides.length < 2) return;
      timer = window.setInterval(() => activate(current + 1), 5600);
    }

    previous?.addEventListener("click", () => activate(current - 1));
    next?.addEventListener("click", () => activate(current + 1));
    dots?.addEventListener("click", (event) => {
      const dot = (event.target as Element).closest<HTMLElement>("[data-slide-dot]");
      if (dot) activate(Number(dot.dataset.slideDot));
    });
    slider.addEventListener("mouseenter", stop);
    slider.addEventListener("mouseleave", start);
    slider.addEventListener("focusin", stop);
    slider.addEventListener("focusout", start);
    slider.addEventListener("keydown", (event) => {
      if (event.key === "ArrowLeft") activate(current - 1);
      if (event.key === "ArrowRight") activate(current + 1);
    });
    slider.addEventListener("touchstart", (event) => {
      startX = event.touches[0].clientX;
    });
    slider.addEventListener("touchend", (event) => {
      const delta = event.changedTouches[0].clientX - startX;
      if (Math.abs(delta) > 48) activate(delta > 0 ? current - 1 : current + 1);
    });

    track?.setAttribute("aria-live", "polite");
    activate(0);
    start();
  }
</script>
