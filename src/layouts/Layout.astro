---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SiteInteractions from "../components/SiteInteractions.astro";
import { team } from "../data/siteData";
import { withBase } from "../utils/paths";
import "../styles/styles.css";

type Props = {
  title: string;
  description: string;
  footerBackHref?: string;
  footerBackLabel?: string;
};

const { title, description, footerBackHref, footerBackLabel } = Astro.props;
const currentPath = Astro.url.pathname;
const normalizedPath = currentPath.replace(import.meta.env.BASE_URL.replace(/\/$/, ""), "") || "/";
const pageTitle = normalizedPath === "/" ? team.name : `${team.name} | ${title}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={withBase(team.emblem)} />
  </head>
  <body>
    <Header currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer backHref={footerBackHref} backLabel={footerBackLabel} />
    <SiteInteractions />
  </body>
</html>
