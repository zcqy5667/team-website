---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { team } from "../data/siteData";
import "../styles/styles.css";

type Props = {
  title: string;
  description: string;
  footerBackHref?: string;
  footerBackLabel?: string;
};

const { title, description, footerBackHref, footerBackLabel } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <Header team={team} currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer backHref={footerBackHref} backLabel={footerBackLabel} />
  </body>
</html>
